# Copy to /opt/mpbt/.env and fill in all values before running docker compose.
# Never commit this file to version control.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Shared by both the game server and the NestJS API.
DATABASE_URL=postgres://mpbt:CHANGEME@db:5432/mpbt
POSTGRES_USER=mpbt
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=mpbt

# ── Game server ────────────────────────────────────────────────────────────────
# Public IP or hostname sent in REDIRECT packets to game clients.
# Clients connect to this address on port 2001 (WORLD_PORT) after login.
# Also exposed via /api/client-config so the launcher can discover it at runtime.
SERVER_HOST=play-solaris.com

# ── NestJS API ─────────────────────────────────────────────────────────────────
# HS256 JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGEME

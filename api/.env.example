# Copy to .env and fill in values for local development.
# In production these are injected by Docker Compose — see deploy/docker-compose.yml.

# PostgreSQL connection string.
DATABASE_URL=postgres://mpbt:mpbt@localhost:5432/mpbt

# HS256 JWT signing secret — must be stable across restarts or all sessions are invalidated.
# Generate with: openssl rand -hex 32
# In production this is set via the VPS .env file.
JWT_SECRET=change-me-in-production

# Allowed cross-origin for cookie credentials (the Next.js frontend origin).
FRONTEND_URL=http://localhost:3000

# API listen port (default 3001).
PORT=3001
